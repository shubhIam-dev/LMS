# -----------------------------------------------------------------------------
# Environment configuration for the LMS backend.
#
#   1. Copy this file to `.env` in the same folder:   cp .env.example .env
#   2. Paste YOUR OWN MongoDB URI into MONGODB_URI below.
#   3. Save. Start the server:                        npm start
#
# `.env` is in .gitignore — your real credentials will never be committed.
# See README.md ("Step 1 — Set up MongoDB") for a full Atlas walkthrough.
# -----------------------------------------------------------------------------

# Your MongoDB connection string. Two common shapes:
#
#   Atlas (free cloud tier — recommended):
#     mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lms?retryWrites=true&w=majority&appName=Cluster0
#
#   Local MongoDB running on your own machine:
#     mongodb://127.0.0.1:27017/lms
#
# Notes:
#   • URL-encode special characters in the password.  @ → %40   # → %23   / → %2F
#   • The `/lms` at the end is the database name. Change it if you want.
#   • DO NOT wrap the value in quotes.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lms?retryWrites=true&w=majority&appName=Cluster0

# Port the API listens on (the frontend expects 9000).
PORT=9000

# Secret used to sign JWT auth tokens. Use a long, random string in production
# (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`).
# If unset, the app falls back to an insecure dev secret — fine for learning,
# never for a real deployment.
JWT_SECRET=change-me-to-a-long-random-string
